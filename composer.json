{
    "name": "codebar-ag/laravel-miro",
    "description": "A simple way to interact with the Miro API in Laravel",
    "keywords": [
        "codebar-ag",
        "laravel-miro",
        "miro",
        "laravel"
    ],
    "homepage": "https://github.com/codebar-ag/laravel-miro",
    "license": "MIT",
    "authors": [
        {
            "name": "codebar AG",
            "email": "hello@codebar.ch",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "saloonphp/laravel-plugin": "^3.0",
        "saloonphp/saloon": "^3.0",
        "spatie/laravel-package-tools": "^1.16",
        "wendelladriel/laravel-validated-dto": "^4.6"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpstan/phpstan": "^2.1",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "CodebarAg\\Miro\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodebarAg\\Miro\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodebarAg\\Miro\\MiroServiceProvider"
            ],
            "aliases": {
                "Miro": "CodebarAg\\Miro\\Facades\\Miro"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
